# ─── Bandit configuration — simulateur Python ────────────────────────────────
# Doc : https://bandit.readthedocs.io/en/latest/config.html
# Format : YAML (bandit >= 1.7)
# Utilisation : bandit -r simulator/ -c simulator/.bandit -ll

skips:
  - B101   # assert — utilisé dans les tests uniquement
  - B311   # random — volontaire dans le simulateur (pas de crypto)

exclude_dirs:
  - .venv
  - __pycache__
  - tests
