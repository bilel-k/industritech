# ─────────────────────────────────────────────────────────────────────────────
# .env.example – Copiez ce fichier en .env et remplissez les valeurs
# IMPORTANT : Ne jamais committer .env dans git !
# ─────────────────────────────────────────────────────────────────────────────

# ─── Mosquitto / MQTT ────────────────────────────────────────────────────────
MQTT_USER_ADMIN=admin
MQTT_PASS_ADMIN=changeme_admin_2026!
MQTT_USER_SENSOR=sensor
MQTT_PASS_SENSOR=changeme_sensor_2026!
MQTT_USER_NODERED=nodered
MQTT_PASS_NODERED=changeme_nodered_2026!

# ─── InfluxDB ────────────────────────────────────────────────────────────────
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=changeme_influx_2026!
INFLUXDB_ORG=industritech
INFLUXDB_BUCKET=iot_data
# Token long (générer avec : openssl rand -hex 32)
INFLUXDB_TOKEN=changeme_token_openssl_rand_hex_32_here

# ─── Grafana ─────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana_2026!

# ─── Webapp ──────────────────────────────────────────────────────────────────
# Origines autorisées pour CORS (séparées par virgule)
CORS_ORIGINS=http://localhost:8080,http://192.168.1.100:8080

# ─── Node-RED ────────────────────────────────────────────────────────────────
NODE_RED_CREDENTIAL_SECRET=changeme_nodered_secret_long_2026
